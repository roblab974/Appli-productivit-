# ─── BASE DE DONNÉES ─────────────────────────────────────────────────────────
# En local sans ces variables : on utilise SQLite local (node:sqlite)
# En production (Vercel) : il FAUT ces variables (Vercel n'a pas de disque persistant)
TURSO_DATABASE_URL=libsql://votre-db.turso.io
TURSO_AUTH_TOKEN=votre-token

# ─── AUTHENTIFICATION (Clerk) ────────────────────────────────────────────────
# Récupérer ces clés sur https://dashboard.clerk.com → ton app → API Keys
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_xxx
CLERK_SECRET_KEY=sk_test_xxx

# URLs Clerk (à laisser tel quel)
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/
